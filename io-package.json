{
  "common": {
    "name": "battery-bms-monitor",
    "version": "1.0.5",
    "news": {
      "1.0.5": {
        "en": "auto download pyserial",
        "zh-cn": "自动下载 pyserial",
        "de": "pyserial automatisch herunterladen"
      }
    },
    "title": "Gobel Battery Monitor",
    "titleLang": {
      "en": "Gobel Battery Monitor",
      "zh-cn": "Gobel 电池监控",
      "de": "Gobel Batteriemonitor"
    },
    "desc": {
      "en": "Battery Monitor adapter by Gobel Power for PACE, JKBMS, and TDT BMS",
      "zh-cn": "由 Gobel Power 开发的适用于 PACE、JKBMS 和 TDT BMS 的电池监控适配器",
      "de": "Batteriemonitor-Adapter von Gobel Power für PACE, JKBMS und TDT BMS"
    },
    "authors": [
      "fancyui"
    ],
    "keywords": [
      "gobel",
      "battery",
      "bms",
      "pace",
      "jkbms",
      "tdt",
      "solar"
    ],
    "license": "Apache-2.0",
    "platform": "Javascript/Node.js",
    "main": "main.js",
    "icon": "battery-bms-monitor.png",
    "enabled": true,
    "extIcon": "https://raw.githubusercontent.com/fancyui/ioBroker.battery-bms-monitor/master/admin/battery-bms-monitor.png",
    "readme": "https://github.com/fancyui/ioBroker.battery-bms-monitor/blob/master/README.md",
    "docs": {
      "en": "README.md",
      "de": "docs/de/README.md",
      "zh-cn": "docs/zh-cn/README.md"
    },
    "loglevel": "info",
    "mode": "daemon",
    "type": "energy",
    "compact": true,
    "connectionType": "local",
    "dataSource": "poll",
    "dependencies": [
      {
        "js-controller": ">=3.0.0"
      }
    ],
    "adminUI": {
      "config": "json"
    }
  },
  "native": {
    "connectionType": "serial",
    "batteryPort": "rs232",
    "bmsType": "PACE_LV",
    "serialPort": "/dev/ttyUSB0",
    "baudRate": 115200,
    "ipAddress": "10.0.0.5",
    "ipPort": 8899,
    "refreshInterval": 5,
    "maxParallel": 16,
    "jkDisplayIndexStart": "01",
    "debug": false,
    "pythonPath": ""
  },
  "objects": [],
  "instanceObjects": [
    {
      "_id": "info",
      "type": "channel",
      "common": {
        "name": "Information"
      },
      "native": {}
    },
    {
      "_id": "info.connection",
      "type": "state",
      "common": {
        "role": "indicator.connected",
        "name": "BMS connection status",
        "type": "boolean",
        "read": true,
        "write": false,
        "def": false
      },
      "native": {}
    }
  ]
}