{
  "i18n": true,
  "type": "tabs",
  "items": {
    "tab_connection": {
      "type": "panel",
      "label": "Connection Settings",
      "items": {
        "connectionType": {
          "type": "select",
          "label": "Connection Type",
          "options": [
            { "value": "serial", "label": "Serial (USB)" },
            { "value": "wifi", "label": "WiFi" },
            { "value": "ethernet", "label": "Ethernet" }
          ],
          "sm": 6,
          "md": 4
        },
        "bmsType": {
          "type": "select",
          "label": "BMS Type",
          "options": [
            { "value": "PACE_LV", "label": "PACE_LV" },
            { "value": "JK_PB", "label": "JK_PB" },
            { "value": "TDT", "label": "TDT" },
            { "value": "PACE_LV_WIFI", "label": "PACE_LV_WIFI" }
          ],
          "sm": 6,
          "md": 4
        },
        "batteryPort": {
          "type": "select",
          "label": "BMS Interface Port",
          "options": [
            { "value": "rs232", "label": "RS232" },
            { "value": "rs485", "label": "RS485" }
          ],
          "sm": 6,
          "md": 4
        },
        "divider_serial": {
          "type": "divider"
        },
        "serialPort": {
          "type": "text",
          "label": "Serial Port Path",
          "help": "e.g. /dev/ttyUSB0 or COM3",
          "hidden": "data.connectionType !== 'serial'",
          "sm": 6,
          "md": 4
        },
        "baudRate": {
          "type": "number",
          "label": "Baud Rate",
          "hidden": "data.connectionType !== 'serial'",
          "sm": 6,
          "md": 4
        },
        "divider_ip": {
          "type": "divider"
        },
        "ipAddress": {
          "type": "text",
          "label": "IP Address",
          "hidden": "data.connectionType === 'serial'",
          "sm": 6,
          "md": 4
        },
        "ipPort": {
          "type": "number",
          "label": "IP Port",
          "hidden": "data.connectionType === 'serial'",
          "sm": 6,
          "md": 4
        }
      }
    },
    "tab_options": {
      "type": "panel",
      "label": "BMS & Scan Options",
      "items": {
        "refreshInterval": {
          "type": "number",
          "label": "Data Refresh Interval (seconds)",
          "min": 1,
          "max": 300,
          "sm": 6,
          "md": 4
        },
        "maxParallel": {
          "type": "number",
          "label": "Max Parallel Packs Scanned",
          "min": 1,
          "max": 16,
          "sm": 6,
          "md": 4
        },
        "jkDisplayIndexStart": {
          "type": "select",
          "label": "JK BMS Display Index Start",
          "options": [
            { "value": "01", "label": "Start from pack_01" },
            { "value": "00", "label": "Start from pack_00" }
          ],
          "hidden": "data.bmsType !== 'JK_PB'",
          "sm": 6,
          "md": 4
        },
        "debug": {
          "type": "checkbox",
          "label": "Enable Debug Mode",
          "help": "Prints verbose protocol frames to adapter logs",
          "sm": 6,
          "md": 4
        },
        "pythonPath": {
          "type": "text",
          "label": "Python Path / Command",
          "help": "Custom Python path (e.g. /usr/bin/python3 or python). Leave empty for default automatic resolution.",
          "sm": 6,
          "md": 4
        }
      }
    },
    "tab_python_help": {
      "type": "panel",
      "label": "Python Setup Guide",
      "items": {
        "help_header": {
          "type": "header",
          "text": "Python Environment Guide (Required: Python 3.8+ & pyserial)",
          "size": 3,
          "sm": 12
        },
        "help_desc": {
          "type": "staticText",
          "text": "This adapter requires Python 3.8 or higher with the pyserial library installed to query the BMS. Follow the instructions below for your system type.",
          "sm": 12
        },
        "divider_help_1": {
          "type": "divider"
        },
        "help_linux_header": {
          "type": "header",
          "text": "1. Linux / Raspberry Pi OS",
          "size": 4,
          "sm": 12
        },
        "help_linux_text": {
          "type": "staticText",
          "text": "Connect to your system via SSH and run the following command to install Python 3 and its virtual environment libraries:\n\nsudo apt-get update && sudo apt-get install -y python3 python3-venv python3-serial",
          "sm": 12
        },
        "divider_help_2": {
          "type": "divider"
        },
        "help_docker_header": {
          "type": "header",
          "text": "2. Docker Containers (ioBroker official image)",
          "size": 4,
          "sm": 12
        },
        "help_docker_text": {
          "type": "staticText",
          "text": "If running inside a Docker container (e.g. on Synology, Portainer, or via docker-compose), edit the container settings and add 'python3 python3-pip python3-serial' to the PACKAGES environment variable. The container will automatically install it on startup.",
          "sm": 12
        },
        "divider_help_3": {
          "type": "divider"
        },
        "help_windows_header": {
          "type": "header",
          "text": "3. Windows System",
          "size": 4,
          "sm": 12
        },
        "help_windows_text": {
          "type": "staticText",
          "text": "If your Windows machine is connected to the internet, the adapter will automatically download and set up a portable Python 3.11 environment with pyserial on startup. If offline or if auto-download fails:\n\n- Download Python (3.8+) from https://www.python.org/downloads/\n- Run the installer and CRITICALLY check the box 'Add Python to PATH'\n- Open command prompt and run: pip install pyserial\n- Or enter the absolute path to python.exe in the 'Python Path / Command' setting.",
          "sm": 12
        }
      }
    }
  }
}
